{
  "name": "odin-social-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "db"
  ],
  "description": "A social media app that allows users to follow each other, make, like, and comment on posts, create profiles, and set profile pictures",
  "main": "index.js",
  "scripts": {
    "dev:backend": "node --env-file=.env --watch backend/src/app.js",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "backend:test": "npm run test --workspace=backend",
    "frontend:test": "npm run test --workspace=frontend",
    "db:test:push": "node --env-file=.env -e \"const { execSync } = require('child_process'); execSync('npx prisma db push --schema=./db/prisma/schema.prisma', { env: { ...process.env, DATABASE_URL: process.env.TEST_DATABASE_URL }, stdio: 'inherit' });\"",
    "db:push": "npx prisma db push --schema=db/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=db/prisma/schema.prisma",
    "db:generate": "PRISMA_SKIP_POSTINSTALL_GENERATE=true npx prisma generate --schema=db/prisma/schema.prisma",
    "db:seed": "node db/prisma/direct-seed.js",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run db:generate && npm run build:frontend",
    "start": "node backend/src/app.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goldenvertex42/odin-social-app.git"
  },
  "keywords": [],
  "author": "Denver Clark, III",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/goldenvertex42/odin-social-app/issues"
  },
  "homepage": "https://github.com/goldenvertex42/odin-social-app#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"  
  },
  "overrides": {
    "js-yaml": "^4.1.2",
    "shell-quote": "^1.8.4",
    "@babel/core": "^7.29.1",
    "vite": "^8.0.16",
    "hono": "^4.12.16",
    "@hono/node-server": "^1.19.13",
    "prisma": {
      "hono": "^4.12.16",
      "@hono/node-server": "^1.19.13"
    }
  }
}
